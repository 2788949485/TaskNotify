<Window x:Class="TaskNotify.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskNotify.Desktop.ViewModels"
        Title="TaskNotify" Height="520" Width="900" MinHeight="320" MinWidth="640"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left menu -->
        <Border Grid.Column="0"
                Background="#FFF4F4F4"
                BorderBrush="#FFE0E0E0"
                BorderThickness="0,0,1,0">
            <Grid Margin="12,18,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,18">
                    <TextBlock Text="TaskNotify" FontSize="18" FontWeight="SemiBold" Foreground="#FF1F1F1F" />
                    <TextBlock Text="后台任务通知" FontSize="11" Foreground="#FF6E6E6E" />
                </StackPanel>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding MenuItems}"
                         SelectedItem="{Binding SelectedMenu, Mode=TwoWay}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Foreground" Value="#FF1F1F1F" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Root" Padding="10,8" CornerRadius="4" Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#FFEAEAEA" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="#FFD6E4FF" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Foreground" Value="#FF1F3E8A" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Glyph}"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="14"
                                           Margin="0,0,10,0"
                                           Foreground="#FF6E6E6E" />
                                <TextBlock Text="{Binding Title}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2"
                           Margin="0,12,0,0"
                           FontSize="10"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#FF8A8A8A"
                           Text="v0.3 Phase 5" />
            </Grid>
        </Border>

        <!-- Right content area -->
        <Grid Grid.Column="1" Margin="20,18,20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,12"
                       FontSize="20" FontWeight="SemiBold"
                       Text="{Binding Navigation.CurrentPage.Title, FallbackValue=TaskNotify}" />

            <ContentControl Grid.Row="1" Content="{Binding Navigation.CurrentPage}" />
        </Grid>
    </Grid>
</Window>
