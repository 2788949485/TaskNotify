<Window x:Class="TaskNotify.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskNotify" Height="360" Width="620" MinHeight="240" MinWidth="420">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="TaskNotify 正在后台监控" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Margin="0,6,0,4" Text="关闭窗口会最小化到系统托盘。仅在进程结果无法确认时提示“进程已结束”。" TextWrapping="Wrap" />
            <TextBlock Margin="0,0,0,16" FontSize="11" Foreground="Gray" Text="{Binding RuntimeStatus}" TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <ListBox Grid.Row="1" ItemsSource="{Binding Completed}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                        <TextBlock Text="{Binding Summary}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
