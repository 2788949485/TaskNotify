<UserControl x:Class="TaskNotify.Desktop.Views.NotificationSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
            CornerRadius="6" Padding="24,18">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="事件类型" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                <CheckBox Margin="0,4"
                          Content="任务成功/失败/退出码未知时通知"
                          IsChecked="True"
                          IsEnabled="False" />
                <CheckBox Margin="0,4"
                          Content="任务等待权限确认时通知（不受冷却限制）"
                          IsChecked="{Binding NotifyOnWaitingForPermission, Mode=TwoWay}" />
                <CheckBox Margin="0,4"
                          Content="推测完成（CPU/磁盘下降）时通知"
                          IsChecked="{Binding NotifyOnPossiblyCompleted, Mode=TwoWay}" />

                <TextBlock Text="节流" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="同一任务冷却秒数" />
                    <TextBox Grid.Column="1"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             Text="{Binding CooldownSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="默认 10 秒。" />
                </Grid>
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="合并窗口秒数" />
                    <TextBox Grid.Column="1"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             Text="{Binding MergeBurstSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="默认 5 秒；同窗口事件合并成一条通知。" />
                </Grid>

                <TextBlock Text="进程级阈值覆盖" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="进程名，例如 python.exe"
                             Text="{Binding NewProcessName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="1"
                             Margin="8,0,0,0"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="运行多少秒后才通知"
                             Text="{Binding NewThresholdSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            Padding="14,4"
                            Content="添加"
                            Command="{Binding AddCommand}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Thresholds}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="{Binding ProcessName}" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text="{Binding Seconds, StringFormat={}{0} 秒}" />
                                <Button Grid.Column="2"
                                        Padding="10,2"
                                        Content="删除"
                                        Command="{Binding RemoveCommand}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="邮箱通知" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />
                <CheckBox Margin="0,4"
                          Content="任务完成时同时发送邮件（与系统通知并行，使用独立的 email.json 配置）"
                          IsChecked="{Binding EmailEnabled, Mode=TwoWay}" />

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="SMTP 服务器" />
                    <TextBox Grid.Column="1"
                             Margin="0,0,8,0"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="例如 smtp.gmail.com"
                             Text="{Binding SmtpHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Text="端口" />
                    <TextBox Grid.Column="3"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             Text="{Binding SmtpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox Grid.Column="4"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Content="SSL/TLS"
                              IsChecked="{Binding UseSsl, Mode=TwoWay}" />
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="用户名" />
                    <TextBox Grid.Column="1"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="通常就是邮箱地址本身"
                             Text="{Binding SmtpUserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="密码" />
                    <PasswordBox Grid.Column="1"
                                 x:Name="EmailPasswordBox"
                                 Padding="6,4"
                                 VerticalContentAlignment="Center"
                                 ToolTip="用 DPAPI 加密存储到 email.json，仅当前 Windows 用户可解密；留空表示沿用已保存的密码"
                                 PasswordChanged="EmailPasswordBox_PasswordChanged" />
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="发件人" />
                    <TextBox Grid.Column="1"
                             Margin="0,0,8,0"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="发件邮箱地址"
                             Text="{Binding FromAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="2"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="发件人显示名（可空）"
                             Text="{Binding FromDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="收件人" />
                    <TextBox Grid.Column="1"
                             Padding="6,4"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinLines="2"
                             MaxLines="4"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="多个地址用逗号、分号或换行分隔"
                             Text="{Binding ToAddresses, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="标题前缀" />
                    <TextBox Grid.Column="1"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             Text="{Binding SubjectPrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Padding="14,4"
                            Content="保存"
                            Command="{Binding SaveEmailCommand}" />
                    <Button Padding="14,4"
                            Margin="8,0,0,0"
                            Content="测试发送"
                            Command="{Binding TestSendEmailCommand}" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               Text="{Binding TestSendStatus}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
