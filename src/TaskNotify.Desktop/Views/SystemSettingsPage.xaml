<UserControl x:Class="TaskNotify.Desktop.Views.SystemSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
            CornerRadius="6" Padding="24,18">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="开机启动" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                <CheckBox Content="登录 Windows 时自动启动 TaskNotify"
                          IsChecked="{Binding AutoStartEnabled, Mode=TwoWay}" />

                <TextBlock Text="诊断" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="日志目录" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding LogDirectory}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="版本" VerticalAlignment="Center" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Text="{Binding Version}" />
                </Grid>
                <Button Margin="0,12,0,0"
                        Padding="14,4"
                        HorizontalAlignment="Left"
                        Content="打开日志目录"
                        Command="{Binding OpenLogFolderCommand}" />

                <TextBlock Text="卸载" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="完整的卸载脚本随安装器在 Phase 9 提供；当前可使用控制面板中的「应用」项移除主程序。" />

                <TextBlock Margin="0,12,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="{Binding LastMessage}" />
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
