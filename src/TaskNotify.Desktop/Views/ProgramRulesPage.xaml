<UserControl x:Class="TaskNotify.Desktop.Views.ProgramRulesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:detection="clr-namespace:TaskNotify.Core.Detection;assembly=TaskNotify.Core">
    <Border Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
            CornerRadius="6" Padding="20,18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="新增规则" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Margin="0,0,8,0"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="进程名，例如 python.exe"
                             Text="{Binding NewProcessName, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Grid.Column="1"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableActions}"
                              SelectedItem="{Binding NewAction, Mode=TwoWay}" />
                    <Button Grid.Column="2"
                            Padding="14,4"
                            Content="添加"
                            Command="{Binding AddCommand}" />
                </Grid>
                <TextBlock Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="行为：Ignore=永不通知；AlwaysNotify=始终通知；Resident=后台常驻不通知。" />
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Rules}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="White"
                      BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                      BorderThickness="0,0,0,1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="规则名"
                                        Width="*"
                                        Binding="{Binding Name}" />
                    <DataGridTextColumn Header="进程匹配"
                                        Width="*"
                                        Binding="{Binding ProcessNamePattern}" />
                    <DataGridTextColumn Header="行为"
                                        Width="120"
                                        Binding="{Binding Action}" />
                    <DataGridTemplateColumn Header="操作" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="删除"
                                        Padding="6,2"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
