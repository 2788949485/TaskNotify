<UserControl x:Class="TaskNotify.Desktop.Views.TaskListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,8"
                   FontSize="11"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Text="{Binding RuntimeStatus}"
                   TextTrimming="CharacterEllipsis" />

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Tasks}"
                 SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="以后总是提醒此类任务"
                                          Command="{Binding PlacementTarget.DataContext.AlwaysRemindCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="以后永不提醒此程序"
                                          Command="{Binding PlacementTarget.DataContext.NeverRemindCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="标记为后台服务（不通知）"
                                          Command="{Binding PlacementTarget.DataContext.MarkAsServiceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="标记为数据工具（不通知）"
                                          Command="{Binding PlacementTarget.DataContext.MarkAsDataToolCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <Separator />
                                <MenuItem Header="通知阈值设为 60 秒"
                                          Command="{Binding PlacementTarget.DataContext.BumpThresholdCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10" CornerRadius="4" Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14" Text="{Binding DisplayName}" />
                            <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="{Binding Summary}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
