<UserControl x:Class="TaskNotify.Desktop.Views.TaskListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,8"
                   FontSize="11"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Text="{Binding RuntimeStatus}"
                   TextTrimming="CharacterEllipsis" />

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Tasks}"
                 Background="Transparent"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10" CornerRadius="4" Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="14" Text="{Binding DisplayName}" />
                            <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="{Binding Summary}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
