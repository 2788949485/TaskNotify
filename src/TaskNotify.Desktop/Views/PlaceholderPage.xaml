<UserControl x:Class="TaskNotify.Desktop.Views.PlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
            CornerRadius="6"
            Padding="32,24">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{Binding Title}" />
            <TextBlock Margin="0,12,0,0" FontSize="13" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Text="{Binding Description}" TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
