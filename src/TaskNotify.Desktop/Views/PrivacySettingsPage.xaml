<UserControl x:Class="TaskNotify.Desktop.Views.PrivacySettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}"
            CornerRadius="6" Padding="24,18">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="历史保留" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                <CheckBox Margin="0,4"
                          Content="应用退出时清除历史任务"
                          IsChecked="{Binding ClearHistoryOnExit, Mode=TwoWay}" />
                <CheckBox Margin="0,4"
                          Content="完全不持久化历史（仅内存）"
                          IsChecked="{Binding DisableHistory, Mode=TwoWay}" />

                <TextBlock Text="命令脱敏" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="额外关键词（正则），匹配到的命令片段会被替换为 ***。" />
                <Grid Margin="0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Padding="6,4"
                             VerticalContentAlignment="Center"
                             ToolTip="正则，例如 api[_-]?key"
                             Text="{Binding NewPattern, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="14,4"
                            Content="添加"
                            Command="{Binding AddPatternCommand}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Patterns}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="{Binding}" />
                                <Button Grid.Column="1"
                                        Padding="10,2"
                                        Content="删除"
                                        Command="{Binding DataContext.RemovePatternCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="本地数据" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="设置" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding SettingsFilePath}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="数据库" VerticalAlignment="Center" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Margin="0,4,0,0"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding DatabasePath}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="日志目录" VerticalAlignment="Center" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Margin="0,4,0,0"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding LogDirectory}" />
                </Grid>

                <Button Margin="0,24,0,8"
                        Padding="14,6"
                        HorizontalAlignment="Left"
                        Content="立即清除历史…"
                        Command="{Binding ClearHistoryCommand}" />
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Text="{Binding LastMessage}" />
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
